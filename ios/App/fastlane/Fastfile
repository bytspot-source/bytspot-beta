default_platform(:ios)

platform :ios do
  desc "Build and upload a new beta to TestFlight"
  lane :beta do
    # Authenticate with App Store Connect API (no 2FA issues in CI)
    api_key = app_store_connect_api_key(
      key_id:        ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:     ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:   ENV["APP_STORE_CONNECT_KEY_CONTENT"],
      is_key_content_base64: false
    )

    # Choose a build number that is always strictly higher than TestFlight,
    # and also unique across GitHub reruns/overlapping CI executions.
    latest = latest_testflight_build_number(
      api_key:        api_key,
      app_identifier: "com.bytspot.app",
      initial_build_number: 63
    )
    next_remote_build = latest.to_i + 1

    github_run_id = ENV["GITHUB_RUN_ID"].to_s[/\d+/].to_i
    github_run_attempt = ENV.fetch("GITHUB_RUN_ATTEMPT", "1").to_i
    ci_build = if github_run_id.positive?
      format("%d%02d", github_run_id, github_run_attempt).to_i
    else
      0
    end

    timestamp_build = Time.now.utc.strftime("%y%m%d%H%M%S").to_i
    candidate_builds = [next_remote_build, timestamp_build]
    candidate_builds << ci_build if ci_build.positive?

    new_build = candidate_builds.max.to_s
    UI.message(
      "Build number candidates → latest+1=#{next_remote_build}, " \
      "timestamp=#{timestamp_build}, " \
      "ci=#{ci_build.positive? ? ci_build : 'n/a'}; using #{new_build}"
    )
    increment_build_number(
      xcodeproj:    "App.xcodeproj",
      build_number: new_build
    )

    # Wire the App Clip target into the Xcode project (idempotent).
    sh "bundle exec ruby ../scripts/add_app_clip_target.rb"

    # Switch Release config to manual signing for CI for both targets
    # (local dev uses Automatic via Xcode, CI uses manual with provisioning profile)
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "App.xcodeproj",
      team_id:               ENV["APPLE_TEAM_ID"],
      targets:               ["App"],
      bundle_identifier:     "com.bytspot.app",
      profile_uuid:          ENV["PROVISIONING_PROFILE_UUID"],
      code_sign_identity:    "Apple Distribution"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "App.xcodeproj",
      team_id:               ENV["APPLE_TEAM_ID"],
      targets:               ["Clip"],
      bundle_identifier:     "com.bytspot.app.Clip",
      profile_uuid:          ENV["APP_CLIP_PROVISIONING_PROFILE_UUID"],
      code_sign_identity:    "Apple Distribution"
    )

    # Build the signed .ipa with embedded App Clip
    build_app(
      project:       "App.xcodeproj",
      scheme:        "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle:          "manual",
        teamID:                ENV["APPLE_TEAM_ID"],
        provisioningProfiles:  {
          "com.bytspot.app"      => ENV["PROVISIONING_PROFILE_UUID"],
          "com.bytspot.app.Clip" => ENV["APP_CLIP_PROVISIONING_PROFILE_UUID"]
        }
      },
      output_directory: "./build",
      output_name:      "Bytspot.ipa",
      clean:            true
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key:                          api_key,
      ipa:                              "./build/Bytspot.ipa",
      skip_waiting_for_build_processing: true,
      changelog:                        "Automated build from GitHub Actions"
    )
  end
end

